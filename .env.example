# Storage mode for the frontend:
#   backend = use the Nitro API + database (default, production)
#   local   = use browser localStorage only (offline development, no login required)
NUXT_PUBLIC_STORAGE_MODE=backend

# SQLite (libSQL) database location. Use a persistent path in Docker (mounted volume).
DATABASE_URL=file:./data/studyplanner.db

# Public base URL of the deployment. The OIDC redirect URI is `${PUBLIC_URL}/auth/callback`.
PUBLIC_URL=http://localhost:3000

# OpenID Connect provider (discovery-based). Point this at your own OIDC provider's
# issuer URL — it must expose `${OIDC_ISSUER}/.well-known/openid-configuration`.
# Examples: https://auth.example.com/realms/myrealm (Keycloak), https://your-tenant.auth0.com, etc.
OIDC_ISSUER=https://auth.example.com
OIDC_CLIENT_ID=your-oauth-client-id
OIDC_CLIENT_SECRET=your-oauth-client-secret
